APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
LOG_DIR=logs

AUTH_JWT_SECRET=<generate_a_long_random_secret>
AUTH_ALLOWED_EMAIL_DOMAIN=ascendanalytics.co
AUTH_COOKIE_NAME=ascend_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_SECONDS=315360000
AUTH_PASSWORD_HASH_ITERATIONS=310000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=rss_pipeline

OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4.1-2025-04-14
OPENAI_PROMPT_VERSION=v1.0

ASSEMBLYAI_API_KEY=<your_assemblyai_api_key>
ASSEMBLYAI_BASE_URL=https://api.assemblyai.com

# Hard-capped at 5 to avoid processing large historical feeds in a single run.
MAX_EPISODES_PER_RUN=5
QUEUE_POLL_INTERVAL_SECONDS=2
RUN_HEARTBEAT_SECONDS=30
STALE_RUN_SECONDS=300
RSS_FETCH_TIMEOUT_SECONDS=10
ASSEMBLYAI_POLL_INTERVAL_SECONDS=5
ASSEMBLYAI_TIMEOUT_SECONDS=600
RUN_WORKER_CONCURRENCY=3
EPISODES_PER_RUN_CONCURRENCY=2
ASSEMBLYAI_MAX_INFLIGHT=6
OPENAI_MAX_INFLIGHT=6
DASHBOARD_REFRESH_SECONDS=3
